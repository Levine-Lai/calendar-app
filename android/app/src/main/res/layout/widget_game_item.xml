<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/game_row"
    style="@style/WidgetGameRow"
    android:layout_width="match_parent"
    android:layout_marginTop="0dp">

    <ImageView
        android:id="@+id/away_logo"
        android:contentDescription="@null"
        style="@style/WidgetTeamLogo" />

    <LinearLayout style="@style/WidgetCenterColumn">
        <TextView
            android:id="@+id/start"
            style="@style/WidgetStartText" />

        <TextView
            android:id="@+id/time"
            style="@style/WidgetTimeText" />

        <TextView
            android:id="@+id/type"
            style="@style/WidgetTypeText" />
    </LinearLayout>

    <ImageView
        android:id="@+id/home_logo"
        android:contentDescription="@null"
        style="@style/WidgetTeamLogo" />
</LinearLayout>
